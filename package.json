{
    "name": "grayscale-toggle",
    "version": "1.0.2",
    "description": "Toggle grayscale effect for monitors with keyboard shortcuts and panel indicator",
    "type": "module",
    "main": "src/extension.ts",
    "scripts": {
        "build": "npm run build:dev",
        "build:dev": "npm run clean && npm run compile:runtime && npm run copy-files && npm run compile-schemas",
        "build:prod": "npm run clean && npm run compile && npm run compile:runtime && npm run copy-files && npm run compile-schemas && npm run package",
        "compile": "tsc --noEmit",
        "compile:runtime": "tsc -p tsconfig.runtime.json",
        "lint": "eslint src/ scripts/ eslint.config.js lint-staged.config.js --max-warnings 0",
        "lint:fix": "eslint src/ scripts/ eslint.config.js lint-staged.config.js --fix",
        "lint:strict": "eslint src/ scripts/ eslint.config.js lint-staged.config.js --max-warnings 0",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/",
        "copy-files": "mkdir -p dist && cp -r build/* dist/ && cp src/metadata.json dist/ && cp src/icon.svg dist/",
        "compile-schemas": "mkdir -p dist/schemas && cp schemas/*.gschema.xml dist/schemas/ && (glib-compile-schemas dist/schemas 2>/dev/null || echo 'Schema compilation will occur during installation')",
        "package": "cd dist && zip -r ../dist/grayscale-toggle@webaheadstudios.com.zip . -x '*.DS_Store' '*/.*'",
        "install:extension": "node scripts/install.js",
        "uninstall:extension": "node scripts/install.js --uninstall",
        "enable:extension": "node scripts/install.js --enable",
        "disable:extension": "node scripts/install.js --disable",
        "extension:status": "node scripts/install.js --status",
        "dev:install": "npm run build:dev && node scripts/install.js --dev",
        "dev:uninstall": "node scripts/install.js --uninstall",
        "dev:nested": "dbus-run-session gnome-shell --nested --wayland",
        "dev:rebuild": "npm run build:dev && echo '🔄 Restart nested shell to load the updated modules'",
        "dev:cycle": "npm run build:dev",
        "install:prod": "npm run build:prod && node scripts/install.js",
        "clean": "rm -rf dist/ build/ coverage/",
        "dev": "npm run dev:install",
        "validate": "npm run compile && npm run lint:strict && npm run format:check",
        "validate:full": "npm run validate && npm run build:prod",
        "test:build": "npm run build:prod && echo 'Build test passed'",
        "prepare": "husky install || true",
        "precommit": "lint-staged",
        "preinstall:extension": "mkdir -p dist",
        "release": "semantic-release",
        "release:dry": "semantic-release --dry-run",
        "update-metadata-version": "node scripts/update-metadata-version.js",
        "docs": "node scripts/generate-docs.js",
        "docs:api": "node scripts/generate-docs.js",
        "validate-metadata": "node scripts/validate-metadata.js"
    },
    "keywords": ["gnome", "gnome-shell", "extension", "grayscale", "accessibility", "toggle"],
    "author": {
        "name": "Luiz Lopes",
        "email": "luiz@webaheadstudios.com",
        "url": "https://webaheadstudios.com"
    },
    "license": "GPL-2.0-or-later",
    "repository": {
        "type": "git",
        "url": "https://github.com/webaheadstudios/grayscale-gnome-extension"
    },
    "bugs": {
        "url": "https://github.com/webaheadstudios/grayscale-gnome-extension/issues"
    },
    "homepage": "https://github.com/webaheadstudios/grayscale-gnome-extension#readme",
    "engines": {
        "node": ">=18.0.0"
    },
    "devDependencies": {
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/exec": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@types/glob": "^9.0.0",
        "@types/node": "^25.3.0",
        "@typescript-eslint/eslint-plugin": "^8.48.0",
        "@typescript-eslint/parser": "^8.48.0",
        "chalk": "^5.3.0",
        "conventional-changelog-conventionalcommits": "^7.0.2",
        "esbuild": "^0.25.10",
        "eslint": "^9.39.1",
        "fast-xml-parser": "^5.4.1",
        "husky": "^9.0.11",
        "lint-staged": "^15.2.10",
        "prettier": "^3.7.3",
        "semantic-release": "^25.0.3",
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "@girs/gjs": "^4.0.0-beta.38",
        "@girs/gnome-shell": "^49.1.0"
    },
    "extensionMetadata": {
        "uuid": "grayscale-toggle@webaheadstudios.com",
        "name": "Grayscale Toggle",
        "shell-version": ["45", "46", "47", "48"],
        "gettext-domain": "grayscale-toggle",
        "settings-schema": "org.gnome.shell.extensions.grayscale-toggle"
    }
}
