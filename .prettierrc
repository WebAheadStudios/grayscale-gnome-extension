{
    "tabWidth": 4,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "quoteProps": "as-needed",
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "avoid",
    "printWidth": 100,
    "proseWrap": "preserve",
    "endOfLine": "lf",
    "bracketSameLine": false,
    "embeddedLanguageFormatting": "auto",
    "htmlWhitespaceSensitivity": "css",
    "insertPragma": false,
    "jsxSingleQuote": true,
    "requirePragma": false,
    "vueIndentScriptAndStyle": false,
    "overrides": [
        {
            "files": "*.{ts,tsx}",
            "options": {
                "parser": "typescript",
                "printWidth": 100,
                "tabWidth": 4
            }
        },
        {
            "files": "*.{scss,css}",
            "options": {
                "parser": "scss",
                "printWidth": 120,
                "tabWidth": 4,
                "singleQuote": false
            }
        },
        {
            "files": "*.json",
            "options": {
                "parser": "json",
                "tabWidth": 4,
                "printWidth": 100
            }
        },
        {
            "files": "*.md",
            "options": {
                "parser": "markdown",
                "printWidth": 80,
                "proseWrap": "always",
                "tabWidth": 4
            }
        }
    ]
}
